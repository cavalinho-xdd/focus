{
	"name": "aurora",
	"version": "1.1.0-alpha.2",
	"description": "A gamified Pomodoro app with AI evaluation.",
	"main": "main/main.js",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"start": "electron .",
		"test": "vitest",
		"start:dev": "node scripts/dev.js",
		"start:build": "node scripts/build.js",
		"package:win": "npm run build && electron-builder --win",
		"package:linux": "npm run build && electron-builder --linux",
		"package:mac": "npm run build && electron-builder --mac"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/cavalinho-xdd/aurora.git"
	},
	"build": {
		"appId": "com.aurora.app",
		"productName": "Aurora",
		"directories": {
			"output": "release"
		},
		"protocols": [
			{
				"name": "Aurora Deep Link",
				"schemes": [
					"aurora"
				]
			}
		],
		"win": {
			"target": [
				"nsis"
			],
			"icon": "build/icon.png"
		},
		"linux": {
			"target": [
				"AppImage",
				"deb"
			],
			"icon": "build/icon.png",
			"category": "Utility"
		},
		"mac": {
			"target": [
				"dmg"
			],
			"icon": "build/icon.png",
			"category": "public.app-category.productivity"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true
		},
		"asar": true,
		"publish": {
			"provider": "github"
		},
		"files": [
			"dist/**/*",
			"main/**/*",
			"package.json"
		]
	},
	"keywords": [],
	"author": {
		"name": "cavalinho-xdd",
		"email": "cavalinho-xdd@github.com"
	},
	"license": "ISC",
	"type": "commonjs",
	"devDependencies": {
		"@tailwindcss/vite": "^4.3.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@vitejs/plugin-react": "^6.0.2",
		"electron": "^42.4.0",
		"electron-builder": "^26.15.3",
		"jsdom": "^29.1.1",
		"jsrepo": "^3.8.0",
		"tailwindcss": "^4.3.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@fontsource/geist-mono": "^5.2.8",
		"@fontsource/geist-sans": "^5.2.5",
		"dotenv": "^17.4.2",
		"electron-updater": "^6.8.9",
		"firebase": "^12.14.0",
		"framer-motion": "^12.40.0",
		"i18next": "^26.3.1",
		"lucide-react": "^1.18.0",
		"mammoth": "^1.12.0",
		"ogl": "^1.0.11",
		"pdf-parse": "^2.4.5",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-i18next": "^17.0.8",
		"react-joyride": "^3.1.0"
	},
	"allowScripts": {
		"@firebase/util@1.15.1": true,
		"electron-winstaller@5.4.0": true,
		"protobufjs@7.6.4": true
	}
}
