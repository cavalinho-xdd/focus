{
  "manifest_version": 3,
  "name": "Aurora Focus Companion",
  "version": "1.0.0",
  "description": "Companion extension for the Aurora desktop app. Blocks distracting websites during your focus sessions.",
  "browser_specific_settings": {
    "gecko": {
      "id": "aurora-companion@cavalinho.com",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "declarativeNetRequest",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:43210/*"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "scripts": ["service_worker.js"]
  },
  "action": {
    "default_title": "Aurora Focus Companion"
  },
  "icons": {
    "128": "icons/icon-128.png"
  }
}
